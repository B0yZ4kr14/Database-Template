# Database Backend API - Environment Configuration

# Application
APP_NAME=Database API
APP_VERSION=2.0.2
DEBUG=false
ENVIRONMENT=production

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Security (REQUIRED - Generate a secure key)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secure-secret-key-min-32-chars-long-change-this

# JWT Settings
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# CORS Origins (comma-separated)
# Development:
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# Production (example):
# CORS_ORIGINS=https://your-domain.com,https://admin.your-domain.com

# Database Default Settings
DB_ENGINE=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=my_database
DB_USER=postgres
DB_PASSWORD=
DB_SSL_MODE=prefer

# Backup Settings
BACKUP_AUTO=false
BACKUP_INTERVAL=daily
BACKUP_RETENTION_DAYS=7
BACKUP_COMPRESSION=true
BACKUP_ENCRYPTION=false

# Logging
LOG_LEVEL=INFO

# Directories
BASE_DIR=/opt/database
DATA_DIR=/opt/database/data
BACKUP_DIR=/opt/database/backups
LOG_DIR=/var/log/database
