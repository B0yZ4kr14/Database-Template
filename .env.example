# =============================================================================
# Database - Configuração de Ambiente
# =============================================================================
# Copie este arquivo para .env e ajuste as variáveis
# =============================================================================

# =============================================================================
# Backend Configuration
# =============================================================================

# Ambiente (development, production)
ENVIRONMENT=production

# Diretórios
DATA_DIR=/opt/database/data
BACKUP_DIR=/opt/database/backups
LOG_DIR=/var/log/database

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# CORS (separado por vírgulas)
CORS_ORIGINS=http://localhost,http://localhost:3000

# =============================================================================
# Database Configuration (Default - PostgreSQL)
# =============================================================================

DB_ENGINE=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=orthoplus
DB_USER=postgres
DB_PASSWORD=
DB_SSL_MODE=prefer

# SQLite (alternativo)
# DB_ENGINE=sqlite
# DB_FILE_PATH=/var/lib/orthoplus/database.db

# MariaDB (alternativo)
# DB_ENGINE=mariadb
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=orthoplus
# DB_USER=root
# DB_PASSWORD=
# DB_CHARSET=utf8mb4

# Firebird (alternativo)
# DB_ENGINE=firebird
# DB_HOST=localhost
# DB_PORT=3050
# DB_NAME=/var/lib/firebird/data/orthoplus.fdb
# DB_USER=SYSDBA
# DB_PASSWORD=masterkey

# =============================================================================
# Backup Configuration
# =============================================================================

BACKUP_AUTO=false
BACKUP_INTERVAL=daily
BACKUP_RETENTION_DAYS=7
BACKUP_COMPRESSION=true
BACKUP_ENCRYPTION=false

# =============================================================================
# Security
# =============================================================================

# JWT Secret (gerar com: openssl rand -hex 32)
# JWT_SECRET=your-secret-key-here

# API Key (opcional)
# API_KEY=your-api-key-here

# =============================================================================
# Logging
# =============================================================================

LOG_LEVEL=INFO
LOG_FORMAT=json

# =============================================================================
# Monitoring (opcional)
# =============================================================================

# Prometheus
# PROMETHEUS_ENABLED=true
# PROMETHEUS_PORT=9090

# Sentry
# SENTRY_DSN=your-sentry-dsn
